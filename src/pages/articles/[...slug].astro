---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const categoryLabels: Record<string, string> = {
  guide: "ガイド",
  calendar: "カレンダー",
  comparison: "比較",
  beginner: "入門",
  money: "購入ガイド",
};

const badgeClass: Record<string, string> = {
  guide: "badge-guide",
  calendar: "badge-calendar",
  comparison: "badge-comparison",
  beginner: "badge-beginner",
  money: "badge-money",
};

const categoryLabel = categoryLabels[article.data.category] ?? "";
const badge = badgeClass[article.data.category] ?? "badge-guide";
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <!-- Article header bar -->
  <div style="background: linear-gradient(135deg, #1a1a2e 0%, #2d1b3d 100%); border-bottom: 3px solid #e94560;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs mb-5" style="color: #9ca3af;" aria-label="breadcrumb">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-white">{article.data.title}</span>
      </nav>

      {categoryLabel && (
        <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mb-4 ${badge}`}>
          {categoryLabel}
        </span>
      )}

      <h1 class="text-2xl sm:text-4xl font-black text-white leading-tight mb-4">
        {article.data.title}
      </h1>
      <p class="text-sm sm:text-base mb-5 leading-relaxed" style="color: #d1d5db;">
        {article.data.description}
      </p>
      <div class="flex items-center gap-4 text-xs" style="color: #9ca3af;">
        <time datetime={article.data.pubDate.toISOString()}>
          公開: {article.data.pubDate.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        {article.data.updatedDate && (
          <time datetime={article.data.updatedDate.toISOString()}>
            更新: {article.data.updatedDate.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        )}
      </div>
    </div>
  </div>

  <!-- Article body -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <article class="prose prose-lg max-w-none
      prose-headings:font-black prose-headings:text-primary
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b
      prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-3
      prose-p:leading-relaxed prose-p:text-gray-700
      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
      prose-strong:text-primary
      prose-ul:my-4 prose-li:my-1
      prose-table:text-sm
    ">
      <Content />
    </article>

    <!-- Back navigation -->
    <nav class="mt-12 pt-8 flex items-center justify-between" style="border-top: 1px solid #e5e7eb;">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:text-accent"
        style="color: #4b5563;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        記事一覧に戻る
      </a>
    </nav>
  </div>
</BaseLayout>
