---
import BaseLayout from "../../layouts/BaseLayout.astro";
import catalog from "../../data/catalog.json";

export function getStaticPaths() {
  return catalog.map((p) => ({
    params: { slug: p.slug },
    props: { performer: p },
  }));
}

interface Performer {
  slug: string;
  name: string;
  top_brands: string[];
  is_active: boolean;
  first_year: string;
  last_year: string;
  url_photobook: string;
  url_kindle: string;
  url_gravure: string;
}

const { performer } = Astro.props as { performer: Performer };
const { name, top_brands, is_active, first_year, url_photobook, url_kindle, url_gravure } = performer;

const title = `${name} グラビア写真集 購入ガイド`;
const description = `${name}のグラビア写真集・雑誌まとめ。${top_brands.slice(0, 3).join("、")}などに出演。Amazon・Kindle購入ガイド。`;
---

<BaseLayout title={title} description={description}>
  <!-- Header -->
  <div style="background: linear-gradient(135deg, #1a1a2e 0%, #2d1b3d 100%); border-bottom: 3px solid #e94560;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <nav class="flex items-center gap-2 text-xs mb-5" style="color: #9ca3af;" aria-label="breadcrumb">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span style="color: #9ca3af;">パフォーマー</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-white">{name}</span>
      </nav>

      <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mb-4 badge-money">
        購入ガイド
      </span>

      <h1 class="text-2xl sm:text-4xl font-black text-white leading-tight mb-4">
        {title}
      </h1>
      <p class="text-sm sm:text-base mb-5 leading-relaxed" style="color: #d1d5db;">
        {description}
      </p>
      <div class="flex flex-wrap items-center gap-3 text-xs" style="color: #9ca3af;">
        {is_active ? (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-green-300 bg-green-900/40">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
            活動中
          </span>
        ) : (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full" style="color: #9ca3af; background: rgba(75,85,99,0.3);">
            活動終了
          </span>
        )}
        {first_year && performer.last_year && !is_active ? (
          <span>活動期間: {first_year}〜{performer.last_year}年</span>
        ) : first_year ? (
          <span>デビュー: {first_year}年〜</span>
        ) : null}
      </div>
    </div>
  </div>

  <!-- Body -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <article class="prose prose-lg max-w-none
      prose-headings:font-black prose-headings:text-primary
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b
      prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-3
      prose-p:leading-relaxed prose-p:text-gray-700
      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
      prose-strong:text-primary
    ">

      <h2>{name}の写真集・グラビアを購入する</h2>

      <p>
        <a href={url_photobook} rel="noopener noreferrer sponsored nofollow">{name}の写真集をAmazonで探す</a>
      </p>
      <p>
        <a href={url_kindle} rel="noopener noreferrer sponsored nofollow">{name} Kindle版をAmazonで探す</a>
      </p>

      {top_brands.length > 0 && (
        <>
          <h2>よく出演するグラビア誌</h2>
          {top_brands.map((brand) => (
            <section>
              <h3>{brand}</h3>
              <p>
                <a
                  href={`https://www.amazon.co.jp/s?k=${encodeURIComponent(brand + " " + name)}&tag=magazinelab-22`}
                  rel="noopener noreferrer sponsored nofollow"
                >
                  {brand} {name} をAmazonで探す
                </a>
              </p>
            </section>
          ))}
        </>
      )}

      <h2>まとめ</h2>
      <p>
        <a href={url_gravure} rel="noopener noreferrer sponsored nofollow">{name}の全グラビア作品をAmazonで見る</a>
      </p>

    </article>

    <nav class="mt-12 pt-8 flex items-center justify-between" style="border-top: 1px solid #e5e7eb;">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:text-accent"
        style="color: #4b5563;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        トップに戻る
      </a>
    </nav>
  </div>
</BaseLayout>
