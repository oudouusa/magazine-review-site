---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="検索" description="グラビア雑誌ガイドの全記事・タレントページを検索できます。">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <h1 class="text-2xl sm:text-3xl font-black mb-2" style="color: #1a1a2e;">サイト内検索</h1>
    <p class="text-sm mb-8" style="color: #6b7280;">記事・タレントページを検索できます。</p>

    <div id="search"></div>
  </div>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    new PagefindUI({
      element: "#search",
      showSubResults: true,
      translations: {
        placeholder: "キーワードで検索...",
        zero_results: "「[SEARCH_TERM]」に一致する記事が見つかりませんでした。",
      },
    });
  });
</script>
