---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="検索" description="グラビア雑誌ガイドの全記事・タレントページを検索できます。">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 sm:py-14" data-pagefind-ignore>
    <h1 class="text-2xl sm:text-3xl font-black mb-2" style="color: #1a1a2e;">サイト内検索</h1>
    <p class="text-sm mb-8" style="color: #6b7280;">ヘッダーの検索ボタン（虫眼鏡アイコン）からも検索できます。</p>

    <!-- Inline search for the dedicated search page -->
    <div id="search-inline"></div>
  </div>
</BaseLayout>

<script type="module">
  async function initSearch() {
    const pagefind = await import("/pagefind/pagefind.js").catch(() => null);
    if (!pagefind) {
      document.getElementById("search-inline").innerHTML =
        '<p style="color:#6b7280;font-size:0.875rem">検索機能は本番環境でのみ利用できます。</p>';
      return;
    }
    await pagefind.init();
    const container = document.getElementById("search-inline");
    const input = document.createElement("input");
    input.type = "search";
    input.placeholder = "キーワードで検索...";
    input.className = "w-full border rounded-lg px-4 py-2 text-sm mb-4";
    input.style.cssText = "border-color:#e5e7eb;outline:none;";
    const results = document.createElement("div");
    results.className = "space-y-4";
    container.appendChild(input);
    container.appendChild(results);

    input.addEventListener("input", async (e) => {
      const q = e.target.value.trim();
      if (!q) { results.innerHTML = ""; return; }
      const res = await pagefind.debouncedSearch(q);
      if (!res) return;
      // Guard: discard result if the query changed while awaiting
      if (input.value.trim() !== q) return;
      const items = await Promise.all(res.results.slice(0, 10).map((r) => r.data()));
      if (input.value.trim() !== q) return;
      if (items.length === 0) {
        results.innerHTML = `<p style="color:#6b7280;font-size:0.875rem">「${q}」に一致する記事が見つかりませんでした。</p>`;
        return;
      }
      results.innerHTML = items.map((item) => `
        <article style="border:1px solid #e5e7eb;border-radius:0.5rem;padding:0.75rem 1rem;">
          <a href="${item.url}" style="font-weight:700;color:#1a1a2e;text-decoration:none;">${item.meta?.title ?? item.url}</a>
          <p style="font-size:0.8rem;color:#6b7280;margin-top:0.25rem;">${item.excerpt}</p>
        </article>
      `).join("");
    });
  }
  initSearch();
</script>
